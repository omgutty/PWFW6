{
  "name": "my-playwright-framework",
  "version": "1.0.0",
  "description": "Enterprise Playwright TypeScript Framework",
  "type": "commonjs",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:mobile": "playwright test --project=mobile-chrome",
    "test:smoke": "playwright test --grep @Smoke",
    "test:regression": "playwright test --grep @Regression",
    "test:p0": "playwright test --grep @P0",
    "test:p1": "playwright test --grep @P1",
    "test:ci": "playwright test --reporter=list,json",
    "test:login": "playwright test src/tests/login.spec.ts",
    "test:inventory": "playwright test src/tests/inventory.spec.ts",
    "test:api": "playwright test src/tests/api.spec.ts",
    "test:hybrid": "playwright test src/tests/hybrid.spec.ts",
    "report:pw": "playwright show-report",
    "docker:build": "docker build -t my-playwright-framework .",
    "docker:run": "docker-compose up playwright",
    "docker:smoke": "docker-compose up smoke",
    "docker:regression": "docker-compose up regression",
    "docker:clean": "docker-compose down && docker rmi my-playwright-framework",
    "lint": "tsc --noEmit",
    "clean": "rmdir /s /q dist test-results playwright-report tta-report 2>nul || true"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.5",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "dotenv": "^17.2.3"
  }
}
